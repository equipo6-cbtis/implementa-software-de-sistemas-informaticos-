Algoritmo MEJORA_DE_LA_SUMA_DE_2_NUMEROS
	Definir NUM1, NUM2, R Como Entero
	Escribir INTRODUVE, EL, PRIMER, NUMERO
	Leer NUM1
	Escribir INTRODUCE, EL, SEGUNDO, NUMERO
	Leer NUM2
	R <- NUM1+NUM2
	Escribir 'EL RESULTADO ES', R
	Si R>0 Entonces
		Escribir 'EL RESULTADO ES UN NUMERO POSITIVO'
	SiNo
		Si R<0 Entonces
			Escribir 'EL RESULTADO ES UN NUMERO NEGATIVO.'
		SiNo
			Escribir 'EL RESULTADO ES CERO.'
		FinSi
	FinSi
FinAlgoritmo

